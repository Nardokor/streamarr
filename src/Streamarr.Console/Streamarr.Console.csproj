<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0</TargetFrameworks>

    <ApplicationIcon>..\Streamarr.Host\Streamarr.ico</ApplicationIcon>
  </PropertyGroup>
  <PropertyGroup Condition="!$(RuntimeIdentifier.StartsWith('win'))">
    <AssemblyName>Streamarr</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Streamarr.Host\Streamarr.Host.csproj" />
    <ProjectReference Include="..\Streamarr.RuntimePatches\Streamarr.RuntimePatches.csproj" />
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <ProjectReference Include="..\Streamarr.Windows\Streamarr.Windows.csproj" />
  </ItemGroup>
  <ItemGroup Condition="!$([MSBuild]::IsOSPlatform('Windows'))">
    <ProjectReference Include="..\Streamarr.Mono\Streamarr.Mono.csproj" />
  </ItemGroup>
</Project>
